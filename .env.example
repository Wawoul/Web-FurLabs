# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/furlabs

# AI Services
# Use 'kieai' for kie.ai API (recommended) or 'comfyui' for self-hosted
AI_PROVIDER=kieai
KIE_API_KEY=your_kie_ai_api_key_here
COMFYUI_URL=http://localhost:8188

# Game Settings
DEFAULT_DRAWING_TIME=180
MAX_PLAYERS_PER_LOBBY=6
